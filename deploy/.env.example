# ── ORBS Network ──
SEED_IP=18.211.83.127
DEV_NODE_HOST=
LAMBDA_SCRIPT_BASE_URL=/vm-lambda/subnet-sync

# ── Sync Configuration ──
CHECK_INTERVAL=300
DEBUG=false

# ── EVM Signing ──
PRIVATE_KEY=

# ── Express Server ──
# Port for the dashboard and status API. Set to 80 for production.
PORT=80

# ── Database ──
# DB_HOST must be "db" when running via docker-compose (the compose service name).
# For local development, use "localhost".
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=committee_sync

# ── Postgres Container ──
# These are read by the postgres:16 Docker image to initialize the database.
# Keep in sync with DB_* values above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=committee_sync
